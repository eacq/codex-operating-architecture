  "excluded_roots": [".system", "_shared", "plugins"],
  "exclusions": {
    "directories": [".git", ".venv", "venv", "node_modules", "__pycache__"],
    "files": [".env", "auth.json", "credentials.json", "token.json", "secrets.json"],
    "extensions": [".key", ".pem", ".p12", ".pfx"]
